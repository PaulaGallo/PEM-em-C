#include <stdio.h>
int main()
{
int a = 10, b = 7, c; //declara as variaveis de a, b e c
	int * p = &a; //declara que o endereço de p deve ser armazenado no endereço 10 da memoria RAM
	int * q = &b; //declara que o endereço de q deve ser armazenado no endereço 7 da memoria RAM 
	int * r = &c; //declara que o endereço de r deve ser armazenado no endereço da memoria RAM que esta alocado o c
	*r = *p; //conteudo de r é igual ao conteudo de p
	*p = *q; //conteudo de p é igual ao conteudo de q
	*q = *r; //conteudo de q é igual ao conteudo de r
	printf("%d  -  %d", a, b); //mostra que a=7 e q = 10
	return 0;
}
