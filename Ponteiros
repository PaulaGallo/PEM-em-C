//Resolução
#include <stdio.h>
int main()
{
	int x, y, *p, *q; //declarando as variáveis, sendo p e q os endereços de memoria
	y = 19; //adicionou o valor 19 na variável y
	p = &y; //adicionou o valor do endereço da variável y na variável p
	x = *p; //adicionou o conteúdo da memória de p, na variável x. então p vale 19 aqui
	x = 7; //muda o conteudo de x, que era 19 para 7
	(*p)++; // adiciona mais 1 no endereço de p, que vira 20
	x--; //tira 1 de x, que era 7 e vira 6
	(*p) = (*p) + x; //pega o conteudo p (que é 20), e soma com o conteudo de x (que é 6)
	printf ("y = %d\n", y); //mostra o resultado da soma que é 26
	*q = 10; //declara que o conteudo de q é 10, mas não foi mostrado em qual endereço, então o S.O bloqueia
	return 0;
}
