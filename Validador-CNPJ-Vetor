#include<stdio.h>
int main()
{   int cnpj[14];
	int m1[12]={5,4,3,2,9,8,7,6,5,4,3,2};
	int m2[13]={6,5,4,3,2,9,8,7,6,5,4,3,2};
	int i;
	
  printf("Entre com os 14 digitos do CNPJ:");
	for(i=0;i<14;i++)
	  {	scanf("%d", &cnpj[i]);
	}
	
  //Cálculo do primeiro dígito verificador
	int soma=0;
	for(i=0; i<12; i++)
	  {	soma = soma + cnpj[i]*m1[i];
	}
	int resto = (soma % 11);
	  if (resto < 2){
	      resto = 0;
	}
	      else 
	          resto = 11 - resto;
	    
	if(resto == cnpj[12]){
		printf("\nPrimeiro verificador valido.");
	}
	else{
		printf("\nErro no primeiro verificador.");
	}
	
	//Cálculo do segubdo dígito verificador
	int soma2=0;
	for(i=0; i<13; i++)
	  {	soma2 = soma2 + cnpj[i]*m2[i];
	}
	int resto2 = (soma2 % 11);
	if (resto2 < 2)
    { resto2 = 0;
	}
	  else 
	        resto2 = 11 - resto2;
	    
	if(resto2 == cnpj[13]){
		printf("\nSegundo verificador valido.");
	}
	else{
		printf("\nErro no segubdo verificador.");
	}
	
    return 0;
}
