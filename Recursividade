/* Objetivo: 2) Crie uma função recursiva que calcule potenciações através de multiplicações sucessivas:
x^y = x * x * x * x ......* x   --> y vezes
Matematicamente, x^0 = 1  e  x^y = x * x^(y-1)
a) Base: expoente == 0 -> resultado = 1
b) x^(y-1) é um pouco mais simples que x^y
c) x^y = x * x^(y-1)
// Link: https://onlinegdb.com/vV5G367bo
*/ 

#include <stdio.h>
 /*2) Crie uma função recursiva que calcule potenciações através de multiplicações sucessivas:

x^y = x * x * x * x ......* x   --> y vezes

a) Base: expoente == 0 -> resultado = 1
    caso mais simples: x^0=1

b) x^(y-1) é um pouco mais simples que x^y
    um pouco mais simples que x^y é x^(y-1)

c) x^y = x * x^(y-1)
    Se eu soubesse quanto vale x^(y-1) como calcularia x^y? Basta multiplicar por x, ou seja:
    x^y = x^(y-1) * x
    
    Tem conteúdo no debug
*/

int pot(int base, int expo){
    if(expo==0) return 1;
    else return pot(base, expo-1) * base;
}

int main()
{
    printf("2^5 = %d\n", pot(2,5));

    return 0;
}

