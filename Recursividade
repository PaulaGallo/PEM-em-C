// Linguagem: C

/* Crie uma função recursiva que calcule divisões através de subtrações sucessivas:
x/y = número de vezes que consigo subtrair y de x (x - y - y - y - y ...... >= 0)
Matematicamente,	se x < y  --> resposta = 0
  caso contrário, x / y = ((x-y)/y) + 1
a) Mais simples de todos: x < y -------> 0
b) Um pouco mais simples: (x-y)/y
c) x / y=((x-y)/y)+1
// Link: https://onlinegdb.com/tbVh_CYUf
*/ 
#include <stdio.h>

float sub(int x, int y){
    if(x<=y) return 0;
    else return ((x-y)/y) + 1;
}

// x / y = ((x-y)/y) + 1

int main()
{
    printf("100/5 = %f\n", sub(100,5));

    return 0;
}

