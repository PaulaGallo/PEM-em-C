// Exercício: Recursividade
// Disciplina: Programação Estruturada e Modular
// Linguagem: C

/* Objetivo: Crie uma função recursiva que calcule multiplicações através de somas sucessivas:
x*y = x + x + x + x ...... + x   -> y vezes
Matematicamente, x*0 = 0  e  x*y = x + x*(y-1)
a) Base: y == 0 -> resultado = 0
b) x*(y-1) é um pouco mais simples que x*y
c)  x*y = x + x*(y-1)
// Link: https://onlinegdb.com/uwB3pES1lZ
*/ 

#include <stdio.h>

int x(int base, int soma){
    if(soma==0) return 0;
    else return x(base, soma-1) + base;
}

int main()
{
    printf("2*5 = %d\n", x(2,5));

    return 0;
}
