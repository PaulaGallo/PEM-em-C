#include <stdio.h>
#include <locale.h>
int procurarLinha (int L, int C, int mat[L][C], int proc) 
{
//aqui você completa ....
//esta função retorna a linha em que proc aparece na matriz
    
    int l, c;
    for (l=0; l<L; l++)
    {   for (c=0; c<C; c++)
        {   if (mat[l][c] == proc)
            {
                    return l;
            }
        }
    }
    return -1;
}

