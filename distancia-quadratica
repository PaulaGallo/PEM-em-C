// Exercício: Distância Quadrática
// Disciplina: Programação Estruturada e Modular
// Linguagem: C
// Objetivo: Crie uma função em C que receba por parâmetro dois vetores de números reais e um número inteiro que represente o tamanho destes vetores; 
// A função deve calcular a chamada distância quadrática de dois vetores. 
// Este cálculo soma os quadrados das diferenças dos valores correspondentes dos dois vetores, 
// ou seja, (A[0] - B[0])² + (A[1] - B[1])² + (A[2] - B[2])² + … + (A[10] - B[10])². 
// Pronto! A assinatura da função é assim: double distanciaQuadratica (double A[ ], double B[ ], int N).

#include <stdio.h>
#include <math.h>

double distanciaQuadratica(double A[], double B[], int N){
    double soma = 0;
    int i;
    
    for (i=0; i<N; i++){
        //soma = soma + (A[i] - B[i]) * (A[i] - B[i]); 
        soma = soma + pow (A[i] - B[i], 2); //biblioteca matematica, com power = potenciação
    }
    return soma;
}

int main()
{
    double A[]={0,3,-2,7,9,11,15,0,0,0,0};
    double B[]={0,4,0,7,9,11,15,0,1,0,1};
    printf("%f", distanciaQuadratica(A, B, 11));
    
    return 0;
}
