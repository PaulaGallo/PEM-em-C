// Exercício: Estatísticas de Temperatura (Matrizes)
// Enunciado: 
// Escreva um programa que receba as temperaturas médias de cada dia de um mês (4 semanas vezes 7 dias) em uma matriz.
// O programa deve calcular e exibir:
// ● A temperatura média da do mês.
// ● A maior e a menor temperatura registrada.
// ● Quantos dias tiveram temperatura acima e abaixo da média calculada.
// Para esta resolução, adaptei o código de vetor acima, para matriz.
// Link: https://onlinegdb.com/-CVkiuX3C

#include <stdio.h>

int main()
{
    float temp [4][7];
    float maior, menor, media;
    int i, j, acima = 0, abaixo = 0;
    float soma = 0;
    
    for (i=0; i<4; i++){
        for (j=0; j<7; j++) {
        printf ("Insira a tempera média da semana %d, dia %d : \n", i+1, j+1);
        scanf ("%f", &temp[i][j]);
        
        soma = soma + temp[i][j];
        
        if (i==0 && j==0) {
           maior = temp[0][0];
           menor = temp[0][0];
        }
        else if (temp[i][j] > maior) {
            maior = temp[i][j];
        }
        else if (temp [i][j]< menor) {
            menor = temp[i][j];
        }
        }
    }

    media = soma/28;
    
    for (i=0; i<4; i++){
        for (j=0; j<7; j++) {
        if (temp[i][j] > media) {
            acima ++;
        }
        else if (temp[i][j] < media) {
            abaixo ++;
        }
        }
    }
    
    printf ("A temperatura média foi de %.2f, sendo a maior temperatura %.2f, e a menor %.2f.", media, maior, menor);
    printf ("Houveram %d dias acima e %d abaixo da media.", acima, abaixo);
    
    return 0;
}

