// Exercício: Conversão de Temperaturas (Função)
// Enunciado: 
// Crie um programa que utilize funções separadas para converter uma temperatura de Celsius para Fahrenheit.
// ● A função converterCelsiusParaFahrenheit(float c) deve receber o valor em Celsius e retornar o valor calculado.
// ● No main, o usuário digita o valor, a função é chamada, e o resultado é exibido com duas casas decimais.
// ● Fórmula: F = (C * 1.8) + 32
// Link: https://onlinegdb.com/QF1mlIaHM

#include <stdio.h>

float converterCelsiusParaFahrenheit(float C) {
    float F;
    F = (C * 1.8) + 32;
    
    return F;
}

int main()
{
    float C=0, F;
    printf ("Insira a temperatura em Celsius:");
    scanf ("%f", &C);
    F = converterCelsiusParaFahrenheit(C);
    printf("A temperatura em Fahrenheit é de: %.2f", F);
  
    return 0;
}
