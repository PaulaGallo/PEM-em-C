// Exercício: Estatísticas de Temperatura (Vetores)
// Enunciado: 
// Escreva um programa que receba as temperaturas médias de cada dia de uma semana (7 dias) em um vetor. 
// O programa deve calcular e exibir:
// ● A temperatura média da semana.
// ● A maior e a menor temperatura registrada.
// ● Quantos dias tiveram temperatura acima e abaixo da média calculada.
// Link: https://onlinegdb.com/j-80UM1KK

#include <stdio.h>

int main()
{
    float temp [7];
    float maior, menor, media;
    int i, acima = 0, abaixo = 0;
    float soma = 0;
    
    for (i=0; i<7; i++){
        printf ("Insira a tempera média do dia %d : \n", i+1);
        scanf ("%f", &temp[i]);
        
        soma = soma + temp[i];
        
        if (i==0) {
           maior = temp[0];
           menor = temp[0];
        }
        else if (temp[i] > maior) {
            maior = temp[i];
        }
        else if (temp [i]< menor) {
            menor = temp[i];
        }
    }

    media = soma/7;
    
    for (i=0; i<7; i++){
        if (temp[i] > media) {
            acima ++;
        }
        else if (temp[i] < media) {
            abaixo ++;
        }
    }
    
    printf ("A temperatura média foi de %.2f, sendo a maior temperatura %.2f, e a menor %.2f.", media, maior, menor);
    printf ("Houveram %d dias acima e %d abaixo da media.", acima, abaixo);
    
    return 0;
}
