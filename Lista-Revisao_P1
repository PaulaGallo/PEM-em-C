// Exercício: Controle de Estoque 3x3 (Matrizes)
// Enunciado: 
// Imagine uma loja com 3 corredores e 3 prateleiras em cada corredor. Crie uma matriz 3x3
// onde cada elemento representa a quantidade de produtos em uma prateleira. O programa deve:
// ● Permitir que o usuário preencha a matriz com as quantidades.
// ● Calcular o total de produtos em cada corredor (soma de cada linha).
// ● Informar o total geral de produtos na loja.
// Link: https://onlinegdb.com/fRhc4zhuA

#include <stdio.h>

int main()
{
    int estoque[3][3];
    int i, j, somaLinha, total = 0;
     
    for (i=0; i<3; i++){
        somaLinha = 0;
        
        for (j=0; j<3; j++){
            printf("Insira a quantidade de produtos do corredor %d, prateleira. %d \n", i+1, j+1);
            scanf ("%d", &estoque[i][j]);
            somaLinha = somaLinha + estoque[i][j];
        }

        printf("Produtos do corredor %d: %d \n", i+1, somaLinha);
        total = total + somaLinha;
    }

    printf("Quantidade total de produtos da loja: %d", total);
    
    return 0;
}
