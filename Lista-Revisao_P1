// Exercício: Estatísticas de Temperatura (Vetores)

#include <stdio.h>

int main()
{
    float temp [7];
    float maior, menor, media;
    int i, acima = 0;
    float soma = 0;
    
    for (i=0; i<7; i++){
        printf ("Insira a tempera média do dia %d : \n", i+1);
        scanf ("%f", &temp[i]);
        
        soma = soma + temp[i];
        
        if (i==0) {
           maior = temp[0];
           menor = temp[0];
        }
        else if (temp[i] > maior) {
            maior = temp[i];
        }
        else if (temp [i]< menor) {
            menor = temp[i];
        }
    }

    media = soma/7;
    
    for (i=0; i<7; i++){
        if (temp[i] > media) {
            acima ++;
        }
    }
    
    printf("E temperatura média foi de %.2f, sendo a maior temperatura %.2f, e a menor %.2f. Houveram %d dias acima da media.", media, maior, menor, acima);
    
    return 0;
}
